<div class="zdy-sections section-block-{{section.id}}{% if settings.banner_animation == 'effect_fade_up' %} scroll-trigger animate--slide-in{% endif %}">
  <div class="{% if section.settings.container == 'fullwidth' %}container-full{% elsif section.settings.container == '1770' %}container-1770{% elsif section.settings.container == '1170' %}container-1170{% else %}container{% endif %}">
    <div class="zdy-sections__blocks text-{{section.settings.content_align}}{% if section.settings.padding_full_width == 65 %} pad-65{% endif %}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'zdy_prodcut_metafields' -%}
            <div class="zdy-block-{{block.settings.zdy_class}}">
              {%- if block.settings.zdy_meta_title != blank -%}
                <h2>{{ block.settings.zdy_meta_title }}</h2>
              {%- endif -%}
              {%- if block.settings.is_description -%}
                {{ product.content }}
              {% else -%}
                {{ product.metafields.zdy[block.settings.zdy_meta_key] }}
              {%- endif -%}
            </div>
            {%- if block.settings.zdy_class -%}
              <style>
                {{ block.settings.zdy_css_content }}
              </style>
              <script>
                {
                  {
                    block.settings.zdy_js_content;
                  }
                }
              </script>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>
<style>
  {%- liquid
      assign zdy_sections_bg = section.settings.zdy_sections_bg
      assign zdy_sections_bg_gradient = section.settings.zdy_sections_bg_gradient
      assign zdy_sections_bg_image = section.settings.zdy_sections_bg_image

      assign mg_top_desktop = section.settings.mg_top_desktop
      assign mg_top_tablet = section.settings.mg_top_tablet
      assign mg_top_mobile = section.settings.mg_top_mobile

      assign mg_bottom_desktop = section.settings.mg_bottom_desktop
      assign mg_bottom_tablet = section.settings.mg_bottom_tablet
      assign mg_bottom_mobile = section.settings.mg_bottom_mobile

      assign padding_full_width = section.settings.padding_full_width

      assign enable_border_top = section.settings.enable_border_top
      assign enable_border_bottom = section.settings.enable_border_bottom
      assign color_border_bottom = section.settings.color_border_bottom
      assign enable_minus_mg_top = section.settings.enable_minus_mg_top
      assign minus_spacing_top = section.settings.minus_spacing_top | append: 'px'
  -%}

  {%- if zdy_sections_bg_image != blank %}
      .section-block-{{section.id}}{background: url({{ zdy_sections_bg_image | img_url: '1920x' }});background-repeat: repeat-x;background-size: cover}
  {%- else -%}
      .section-block-{{section.id}}{background: {% if zdy_sections_bg_gradient != blank %}{{ zdy_sections_bg_gradient }}{% else %}{{ zdy_sections_bg }}{% endif %}}
  {%- endif -%}
  {%- if enable_minus_mg_top -%}


  {%- endif -%}
  @media (min-width: 1200px) {.section-block-{{section.id}} {padding-top: {{ mg_top_desktop | append: 'px' }};padding-bottom: {{ mg_bottom_desktop | append: 'px' }}}}
  @media (min-width: 1025px) {
      {%- if section.settings.container == 'fullwidth' -%}
          .section-block-{{section.id}} .container-full {padding-left: {{ padding_full_width | append: 'px' }};padding-right: {{ padding_full_width | append: 'px' }}}
      {%- endif -%}

      {%- if enable_border_top -%}
          .section-block-{{section.id}} {border-top: 1px solid {{ color_border_bottom }}}
      {%- endif -%}

      {%- if enable_border_bottom -%}
          .section-block-{{section.id}} {border-bottom: 1px solid {{ color_border_bottom }}}
      {%- endif -%}
      {%- if enable_minus_mg_top -%}
          .section-block-{{section.id}} {position: relative;margin-top: {{ minus_spacing_top }}}
          {%- if section.settings.container == 'fullwidth' -%}
              .section-block-{{section.id}} {
                  margin-left: {{ padding_full_width | append: 'px' }};
                  margin-right: {{ padding_full_width | append: 'px' }};
              }
          {%- endif -%}
      {%- endif -%}
  }
  @media (min-width: 1025px) and (max-width: 1280px) {
      {%- if enable_minus_mg_top -%}
          {%- if padding_full_width == 80 -%}
              .section-block-{{section.id}} {margin-left: 40px;margin-right: 40px}
              .section-block-{{section.id}} .container-full {padding-left: 40px;padding-right: 40px}
          {%- endif -%}
      {%- endif -%}
  }
  @media (min-width: 768px) and (max-width: 1199px) {.section-block-{{section.id}} {padding-top: {{ mg_top_tablet | append: 'px' }};padding-bottom: {{ mg_bottom_tablet | append: 'px' }}}}
  @media (max-width: 1024px) {
      {%- if section.settings.container == 'fullwidth' -%}
          .section-block-{{section.id}} .container-full {padding-left: 15px;padding-right: 15px}
      {%- endif -%}
      {%- if enable_minus_mg_top -%}
          .section-block-{{section.id}} {
              margin-left: 30px;
              margin-right: 30px;
              margin-top: -50px;
              position: relative;
          }

      {%- endif -%}
  }
  @media (max-width: 767px) {
      .section-block-{{section.id}} {padding-top: {{ mg_top_mobile | append: 'px' }};padding-bottom: {{ mg_bottom_mobile | append: 'px' }}}
      {%- if section.settings.container == 'fullwidth' -%}
          .section-block-{{section.id}} .container-full {padding-left: 10px;padding-right: 10px}
      {%- endif -%}
      {%- if enable_minus_mg_top -%}
          .section-block-{{section.id}} {
              margin-left: 0;
              margin-right: 0;
              margin-top: -1px;
          }
      {%- endif -%}
  }
</style>

{% schema %}
{
  "name": "Zdy sections",
  "class": "sections-zdy-sections",
  "settings": [
    {
      "type": "header",
      "content": "t:settings_schema.general.name"
    },
    {
      "type": "select",
      "id": "container",
      "label": "t:sections.layout.container.option",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "t:sections.layout.container.option1"
        },
        {
          "value": "1170",
          "label": "t:sections.layout.container.option4"
        },
        {
          "value": "1770",
          "label": "t:sections.layout.container.option3"
        },
        {
          "value": "fullwidth",
          "label": "t:sections.layout.container.option2"
        }
      ]
    },
    {
      "type": "range",
      "id": "padding_full_width",
      "label": "t:sections.layout.container.padding_full_width",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "t:sections.layout.fontsize.fontsize_title.unit",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "enable_border_top",
      "label": "t:sections.layout.container.enable_border_top",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_border_bottom",
      "label": "t:sections.layout.container.enable_border_bottom",
      "default": false
    },
    {
      "type": "color",
      "id": "color_border_bottom",
      "label": "t:settings_schema.colors.settings.colors_name.border_color",
      "default": "#e8e8e8"
    },
    {
      "type": "checkbox",
      "id": "enable_minus_mg_top",
      "label": "t:sections.product_block.settings.general.enable_minus_spacing_top",
      "default": false,
      "info": "t:sections.product_block.settings.general.minus_spacing_top_info"
    },
    {
      "type": "range",
      "id": "minus_spacing_top",
      "label": "t:sections.product_block.settings.general.minus_spacing_top",
      "default": -100,
      "min": -100,
      "max": 0,
      "step": 1,
      "unit": "t:sections.layout.mg_desktop.unit"
    },
    {
      "type": "color",
      "id": "zdy_sections_bg",
      "label": "t:settings_schema.colors.settings.colors_name.background_color_2",
      "default": "#fff"
    },
    {
      "type": "color_background",
      "id": "zdy_sections_bg_gradient",
      "label": "t:settings_schema.colors.settings.colors_name.background_color_gradient"
    },
    {
      "type": "image_picker",
      "id": "zdy_sections_bg_image",
      "label": "t:settings_schema.colors.settings.colors_name.background_image"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "t:sections.general.settings.alignment.label__1",
      "options": [
        {
          "value": "left",
          "label": "t:settings_schema.typography.settings.type_button_font.left"
        },
        {
          "value": "center",
          "label": "t:settings_schema.typography.settings.type_button_font.center"
        },
        {
          "value": "right",
          "label": "t:settings_schema.typography.settings.type_button_font.right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:sections.layout.margin_top"
    },
    {
      "type": "range",
      "id": "mg_top_desktop",
      "label": "t:sections.layout.mg_desktop.label",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "t:sections.layout.mg_desktop.unit",
      "default": 50
    },
    {
      "type": "range",
      "id": "mg_top_tablet",
      "label": "t:sections.layout.mg_tablet.label",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "t:sections.layout.mg_desktop.unit",
      "default": 50
    },
    {
      "type": "range",
      "id": "mg_top_mobile",
      "label": "t:sections.layout.mg_mobile.label",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "t:sections.layout.mg_desktop.unit",
      "default": 50
    },
    {
      "type": "header",
      "content": "t:sections.layout.margin_bottom"
    },
    {
      "type": "range",
      "id": "mg_bottom_desktop",
      "label": "t:sections.layout.mg_desktop.label",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "t:sections.layout.mg_desktop.unit",
      "default": 50
    },
    {
      "type": "range",
      "id": "mg_bottom_tablet",
      "label": "t:sections.layout.mg_tablet.label",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "t:sections.layout.mg_desktop.unit",
      "default": 50
    },
    {
      "type": "range",
      "id": "mg_bottom_mobile",
      "label": "t:sections.layout.mg_mobile.label",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "t:sections.layout.mg_desktop.unit",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "zdy_prodcut_metafields",
      "name": "自定义产品元字段",
      "settings": [
        {
          "type": "header",
          "content": "自定义产品元字段",
          "info": "该块只能在产品详情页使用"
        },
        {
          "type": "text",
          "id": "zdy_meta_title",
          "label": "标题"
        },
        {
          "type": "checkbox",
          "id": "is_description",
          "label": "是否是描述",
          "default": true
        },
        {
          "type": "text",
          "id": "zdy_meta_key",
          "label": "zdy空间的键值",
          "info": "填写zdy空间键值,注意，当是否是描述为true时，该值无效"
        },
        {
          "type": "text",
          "id": "zdy_class",
          "label": "zdy-block-类名",
          "info": "方便写css",
          "default": "default"
        },
        {
          "type": "textarea",
          "id": "zdy_css_content",
          "label": "zdy样式的内容",
          "info": "zdy-block-类名必须填写，否则无效"
        },
        {
          "type": "textarea",
          "id": "zdy_js_content",
          "label": "zdy_js的内容",
          "info": "zdy-block-类名必须填写，否则无效"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zdy sections",
      "blocks": [
        {
          "type": "zdy_prodcut_metafields"
        }
      ]
    }
  ]
}
{% endschema %}
